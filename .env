# This file is the main environment file for Symfony
# The real secrets are in .env.local (git-ignored)
# Keep this file versionned - it contains DEFAULTS and EXAMPLES only

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=true
DEFAULT_URI=http://localhost:8000
###< symfony/framework-bundle ###

###> symfony/console ###
# Defaults - override in .env.local for production values
###< symfony/console ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
###< doctrine/doctrine-bundle ###

###> symfony/swiftmailer-bundle ###
MAILER_DSN=null://localhost
###< symfony/swiftmailer-bundle ###

###> knpuniversity/oauth2-client-bundle ###
# Google OAuth (optional) - set in .env.local if using
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
###< knpuniversity/oauth2-client-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=true
###< symfony/messenger ###

###> symfony/mailer ###
# MAILER_DSN=smtp://user:pass@smtp.example.com:587?encryption=tls&auth_mode=login
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###
