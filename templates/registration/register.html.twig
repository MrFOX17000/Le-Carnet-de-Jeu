{% extends 'base.html.twig' %}

{% block title %}Inscription - Carnet de Jeu{% endblock %}

{% block body %}
    <section class="auth-page">
        <div class="auth-card">
            <p class="eyebrow">Bienvenue</p>
            <h1 class="auth-title">Inscription</h1>
            <p class="auth-subtitle">Créez votre compte pour lancer vos groupes et suivre vos sessions.</p>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm, { attr: { class: 'auth-form' } }) }}
                {{ form_row(registrationForm.email) }}
                {{ form_row(registrationForm.plainPassword, {
                    label: 'Mot de passe'
                }) }}
                {{ form_row(registrationForm.agreeTerms) }}

                <button type="submit" class="btn btn-primary btn-large">Créer mon compte</button>
            {{ form_end(registrationForm) }}

            <div class="auth-oauth">
                {% if google_oauth_enabled|default(false) %}
                    <div class="auth-oauth-divider"><span>ou</span></div>
                    <a class="btn btn-secondary btn-large btn-google" href="{{ path('connect_google') }}">
                        <svg class="btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.3 14.7 2.4 12 2.4 6.7 2.4 2.4 6.7 2.4 12s4.3 9.6 9.6 9.6c5.5 0 9.2-3.9 9.2-9.3 0-.6-.1-1.1-.2-1.5H12z"/>
                        </svg>
                        Continuer avec Google
                    </a>
                {% endif %}
            </div>

            <p class="auth-switch">Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a></p>
        </div>
    </section>
{% endblock %}
