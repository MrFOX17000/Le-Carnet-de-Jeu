{% extends 'base.html.twig' %}

{% block title %}Inscription - Carnet de Jeu{% endblock %}

{% block body %}
    <section class="auth-page">
        <div class="auth-card">
            <p class="eyebrow">Bienvenue</p>
            <h1 class="auth-title">Inscription</h1>
            <p class="auth-subtitle">Creez votre compte pour lancer vos groupes et suivre vos sessions.</p>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm, { attr: { class: 'auth-form' } }) }}
                {{ form_row(registrationForm.email) }}
                {{ form_row(registrationForm.plainPassword, {
                    label: 'Mot de passe'
                }) }}
                {{ form_row(registrationForm.agreeTerms) }}

                <button type="submit" class="btn btn-primary btn-large">Creer mon compte</button>
            {{ form_end(registrationForm) }}

            <p class="auth-switch">Deja inscrit ? <a href="{{ path('app_login') }}">Se connecter</a></p>
        </div>
    </section>
{% endblock %}
