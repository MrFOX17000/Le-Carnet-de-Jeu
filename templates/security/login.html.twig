{% extends 'base.html.twig' %}

{% block title %}Connexion - Carnet de Jeu{% endblock %}

{% block body %}
<section class="auth-page">
    <div class="auth-card">
        <p class="eyebrow">Bon retour</p>
        <h1 class="auth-title">Connexion</h1>
        <span class="sr-only">Please sign in</span>
        <p class="auth-subtitle">Accédez à vos groupes, vos sessions et vos statistiques.</p>

        {% if error %}
            <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="flash flash-success">
                Connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.
                <a href="{{ logout_path() }}">Se déconnecter</a>
            </div>
        {% endif %}

        <form method="post" class="auth-form">
            <label for="inputEmail">Email</label>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" autocomplete="email" required>

            <label for="inputPassword">Mot de passe</label>
            <input type="password" name="password" id="inputPassword" autocomplete="current-password" required>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <label class="inline-check">
                <input type="checkbox" name="_remember_me"> Se souvenir de moi
            </label>

            <button class="btn btn-primary btn-large" type="submit">Se connecter</button>
        </form>

        <div class="auth-oauth">
            {% if google_oauth_enabled %}
                <div class="auth-oauth-divider"><span>ou</span></div>
                <a class="btn btn-secondary btn-large btn-google" href="{{ path('connect_google') }}">
                    <svg class="btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.3 14.7 2.4 12 2.4 6.7 2.4 2.4 6.7 2.4 12s4.3 9.6 9.6 9.6c5.5 0 9.2-3.9 9.2-9.3 0-.6-.1-1.1-.2-1.5H12z"/>
                    </svg>
                    Continuer avec Google
                </a>
            {% else %}
                <p class="auth-oauth-note">Connexion Google indisponible : renseignez GOOGLE_CLIENT_ID et GOOGLE_CLIENT_SECRET.</p>
            {% endif %}
        </div>

        <p class="auth-switch">Pas encore de compte ? <a href="{{ path('app_register') }}">Créer un compte</a></p>
    </div>
</section>
{% endblock %}
