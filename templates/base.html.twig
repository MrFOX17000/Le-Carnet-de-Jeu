<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Carnet de Jeu{% endblock %}</title>
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('images/brand/icon-carnet-de-jeu.png') }}">
        <link rel="icon" type="image/webp" href="{{ asset('images/brand/icon-carnet-de-jeu.webp') }}">
        <link rel="apple-touch-icon" href="{{ asset('images/brand/icon-carnet-de-jeu.png') }}">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="theme-classic">
        <header class="site-header">
            <div class="site-header-inner">
                <a class="brand" href="{{ path('app_home') }}" aria-label="Accueil Carnet de Jeu">
                    <picture>
                        <source srcset="{{ asset('images/brand/icon-carnet-de-jeu.webp') }}" type="image/webp">
                        <img class="brand-logo" src="{{ asset('images/brand/icon-carnet-de-jeu.png') }}" alt="Icone Carnet de Jeu">
                    </picture>
                    <span>Carnet de Jeu</span>
                </a>
                <nav class="site-nav" aria-label="Navigation principale">
                    {% if app.user %}
                        <div class="site-nav-main">
                            <a href="{{ path('app_home') }}">Accueil</a>
                            <a href="{{ path('dashboard') }}">Dashboard</a>
                            <a href="{{ path('group_index') }}">Groupes</a>
                            <a href="{{ path('my_profile') }}">Profil</a>
                        </div>
                        <div class="site-nav-user">
                            <a class="btn btn-secondary btn-sm" href="{{ path('group_create_form') }}">Nouveau groupe</a>
                            <span class="user-chip">{{ app.user.displayName ?: app.user.email }}</span>
                            <a href="{{ path('app_logout') }}">Déconnexion</a>
                        </div>
                    {% else %}
                        <a href="{{ path('app_home') }}">Accueil</a>
                        <a href="{{ path('app_login') }}">Connexion</a>
                        <a href="{{ path('app_register') }}">Inscription</a>
                    {% endif %}
                </nav>
            </div>
        </header>

        <main class="page-shell">
            {% for message in app.flashes('success') %}
                <div class="flash flash-success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="flash flash-error">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('verify_email_error') %}
                <div class="flash flash-error">{{ message }}</div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="site-footer">
            <div class="site-footer-inner">
                <p>© {{ "now"|date("Y") }} Carnet de Jeu. Suivi de sessions en groupe.</p>
                <nav class="site-footer-nav" aria-label="Liens de pied de page">
                    <a href="{{ path('app_home') }}">Accueil</a>
                    {% if app.user %}
                        <a href="{{ path('dashboard') }}">Dashboard</a>
                        <a href="{{ path('group_index') }}">Groupes</a>
                        <a href="{{ path('my_profile') }}">Profil</a>
                    {% else %}
                        <a href="{{ path('app_login') }}">Connexion</a>
                        <a href="{{ path('app_register') }}">Inscription</a>
                    {% endif %}
                </nav>
            </div>
        </footer>
    </body>
</html>
