{% extends "base.html.twig" %}

{% block title %}Entrée - {{ session.activity.name }}{% endblock %}

{% block body %}
<section class="entry-show-page">
    <header class="entry-show-header">
        <div>
            <p class="entry-kicker">{{ group.name }} · <a href="{{ path('session_show', {groupId: group.id, sessionId: session.id}) }}">{{ session.activity.name }} du {{ session.playedAt|date('d/m/Y') }}</a></p>
            <h1>{{ entry.label ? entry.label : (entry.type.value == 'match' ? 'Match' : 'Tour de classement') }}</h1>
            <p class="entry-show-meta">{{ entry.type.value == 'match' ? 'Match' : 'Classement' }} · {{ session.activity.name }}</p>
        </div>
        <div class="entry-show-actions">
            <a href="{{ path('session_show', {groupId: group.id, sessionId: session.id}) }}" class="btn btn-secondary">← Retour à la session</a>
            {% if canManage %}
                <form method="post" action="{{ path('entry_delete', {groupId: group.id, sessionId: session.id, entryId: entry.id}) }}" onsubmit="return confirm('Supprimer cette entrée ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-entry-' ~ entry.id) }}">
                    <button type="submit" class="btn btn-outline-danger">Supprimer</button>
                </form>
            {% endif %}
        </div>
    </header>

    <article class="entry-result-card">
        <h2>Résultats</h2>
        {% if entry.type.value == 'match' and entry.entryMatch %}
            {% set homeWon = entry.entryMatch.homeScore > entry.entryMatch.awayScore %}
            {% set awayWon = entry.entryMatch.awayScore > entry.entryMatch.homeScore %}
            {% set isDraw = entry.entryMatch.homeScore == entry.entryMatch.awayScore %}
            <div class="entry-match-board">
                <div class="entry-match-side {{ homeWon ? 'winner' : '' }}">
                    {% if homeWon %}<span class="entry-match-result-label">✓ Gagnant</span>{% elseif isDraw %}<span class="entry-match-result-label entry-match-result-draw">= Égalité</span>{% endif %}
                    <p class="team-name">{{ entry.entryMatch.homeName }}</p>
                    <p class="team-score">{{ entry.entryMatch.homeScore }}</p>
                </div>
                <p class="match-separator">—</p>
                <div class="entry-match-side {{ awayWon ? 'winner' : '' }}">
                    {% if awayWon %}<span class="entry-match-result-label">✓ Gagnant</span>{% elseif isDraw %}<span class="entry-match-result-label entry-match-result-draw">= Égalité</span>{% endif %}
                    <p class="team-name">{{ entry.entryMatch.awayName }}</p>
                    <p class="team-score">{{ entry.entryMatch.awayScore }}</p>
                </div>
            </div>
        {% elseif entry.scores|length > 0 %}
            {% set sortedScores = entry.scores|sort((a, b) => b.score <=> a.score) %}
            {% set medals = ['🥇', '🥈', '🥉'] %}
            <ol class="entry-score-podium">
                {% for idx, score in sortedScores %}
                    <li class="entry-score-row {{ idx == 0 ? 'rank-1' : (idx == 1 ? 'rank-2' : (idx == 2 ? 'rank-3' : '')) }}">
                        <span class="entry-score-rank">{{ medals[idx] is defined ? medals[idx] : '#' ~ (idx + 1) }}</span>
                        <span class="entry-score-name">{{ score.participantName }}</span>
                        <strong class="entry-score-value">{{ score.score }}</strong>
                    </li>
                {% endfor %}
            </ol>
        {% else %}
            <p class="entry-show-empty">Aucun score enregistré.</p>
        {% endif %}
    </article>

    <p class="entry-meta">
        Créée par <strong>{{ entry.createdBy.displayName ?? entry.createdBy.email }}</strong>
        le {{ entry.createdAt|date('d/m/Y à H:i') }}
    </p>
</section>
{% endblock %}
