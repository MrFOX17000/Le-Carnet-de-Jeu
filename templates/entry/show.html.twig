{% extends "base.html.twig" %}

{% block title %}Entrée - {{ session.activity.name }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>{{ entry.label ? entry.label : "Entrée de " ~ entry.createdBy.email }}</h1>
            <p class="text-muted">
                Session {{ session.activity.name }} du {{ session.playedAt|date('d/m/Y H:i') }}
            </p>
        </div>
        <a href="{{ path('session_show', {'groupId': group.id, 'sessionId': session.id}) }}" class="btn btn-secondary">Retour</a>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Résultats</h5>
        </div>
        <div class="card-body">
            {% if entry.type.value == 'match' and entry.entryMatch %}
                <div class="d-flex align-items-center justify-content-center gap-3 fs-4">
                    <strong>{{ entry.entryMatch.homeName }}</strong>
                    <span class="badge bg-dark">{{ entry.entryMatch.homeScore }} - {{ entry.entryMatch.awayScore }}</span>
                    <strong>{{ entry.entryMatch.awayName }}</strong>
                </div>
            {% elseif entry.scores|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Rang</th>
                                <th>Participant</th>
                                <th class="text-end">Score</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% set sortedScores = entry.scores|sort((a, b) => b.score <=> a.score) %}
                            {% for idx, score in sortedScores %}
                                <tr>
                                    <td>
                                        <strong>#{{ idx + 1 }}</strong>
                                    </td>
                                    <td>{{ score.participantName }}</td>
                                    <td class="text-end">
                                        <span class="badge bg-primary">{{ score.score }}</span>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-muted mb-0">Aucun score enregistré</p>
            {% endif %}
        </div>
    </div>

    <div class="mt-4 text-muted small">
        <p>Créée par {{ entry.createdBy.email }} le {{ entry.createdAt|date('d/m/Y H:i') }}</p>
    </div>
</div>
{% endblock %}
