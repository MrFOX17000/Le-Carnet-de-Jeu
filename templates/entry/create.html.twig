{% extends "base.html.twig" %}

{% block title %}Créer une entrée - {{ activity.name }}{% endblock %}

{% block body %}
{% set activityMeta = activity_meta(activity.name, activity.contextMode.value) %}
<section class="entry-create-page">
    <div class="entry-create-card">
        <p class="entry-kicker"><a href="{{ path('session_show', {groupId: group.id, sessionId: session.id}) }}">{{ group.name }} · {{ session.playedAt|date('d/m/Y') }}</a> · Nouvelle entrée</p>
        <nav class="flow-steps" aria-label="Progression de création">
            <span class="flow-step is-done"><strong>1</strong> Activité</span>
            <span class="flow-step is-done"><strong>2</strong> Session</span>
            <span class="flow-step is-active"><strong>3</strong> Résultats</span>
        </nav>
        <h1>
            Nouvelle entrée pour
            <span class="activity-mini-badge" style="--activity-accent: {{ activityMeta.accent }}; --activity-background: {{ activityMeta.background }}; --activity-foreground: {{ activityMeta.foreground }};">
                {% if activityMeta.iconUrl %}
                    <img src="{{ activityMeta.iconUrl }}" alt="{{ activityMeta.iconAlt }}" loading="lazy">
                {% else %}
                    <span>{{ activityMeta.shortLabel }}</span>
                {% endif %}
                {{ activity.name }}
            </span>
        </h1>
        <p class="text-muted">Exemple : Alice 12, Bob 9, Charlie 7 — saisie rapide par classement.</p>
        <div class="session-flow-help" role="note" aria-label="Aide saisie résultats">
            <p><strong>Rapide :</strong> clique un membre pour l'ajouter, ou utilise le sélecteur pour auto-remplir son nom.</p>
        </div>

        <form method="POST" class="entry-create-form">
            <div class="mb-3">
                <label for="label" class="form-label">Titre de l'entrée (optionnel)</label>
                <input type="text" class="form-control" id="label" name="label" placeholder="Ex: Manche 1, Finale, etc.">
                <div class="session-title-tools">
                    <button type="button" class="btn btn-secondary btn-sm" id="entry-generate-label">Générer un titre automatiquement</button>
                    <span class="session-auto-hint" id="entry-label-auto-hint" aria-live="polite"></span>
                </div>
            </div>

            <div class="mb-4 entry-create-scores">
                <h2>Scores</h2>
                <div class="entry-member-quickadd" aria-label="Ajout rapide de membres">
                    {% for membership in groupMembers %}
                        {% set memberLabel = membership.user.displayName ?: membership.user.email %}
                        <button type="button" class="activity-mini-badge entry-member-chip" data-member-id="{{ membership.user.id }}" data-member-label="{{ memberLabel|e('html_attr') }}">
                            <span>{{ memberLabel|slice(0, 2)|upper }}</span>
                            {{ memberLabel }}
                        </button>
                    {% endfor %}
                </div>
                <p class="entry-auto-hint" id="entry-auto-hint" aria-live="polite"></p>
                <datalist id="participant-name-suggestions">
                    {% for membership in groupMembers %}
                        {% set memberLabel = membership.user.displayName ?: membership.user.email %}
                        <option value="{{ memberLabel }}"></option>
                    {% endfor %}
                </datalist>
                <div id="scores-container">
                    <div class="score-row input-group mb-2">
                        <input type="text" class="form-control" name="participant_names[]" list="participant-name-suggestions" placeholder="Nom du participant" required>
                        <input type="number" step="0.01" class="form-control" name="scores[]" placeholder="Score" required>
                        <select class="form-control" name="participant_user_ids[]">
                            <option value="">Membre lié (optionnel)</option>
                            {% for membership in groupMembers %}
                                {% set memberLabel = membership.user.displayName ?: membership.user.email %}
                                <option value="{{ membership.user.id }}" data-member-label="{{ memberLabel|e('html_attr') }}">{{ memberLabel }}</option>
                            {% endfor %}
                        </select>
                        <button type="button" class="btn btn-outline-danger remove-score" style="display: none;">Supprimer</button>
                    </div>
                    <div class="score-row input-group mb-2">
                        <input type="text" class="form-control" name="participant_names[]" list="participant-name-suggestions" placeholder="Nom du participant" required>
                        <input type="number" step="0.01" class="form-control" name="scores[]" placeholder="Score" required>
                        <select class="form-control" name="participant_user_ids[]">
                            <option value="">Membre lié (optionnel)</option>
                            {% for membership in groupMembers %}
                                {% set memberLabel = membership.user.displayName ?: membership.user.email %}
                                <option value="{{ membership.user.id }}" data-member-label="{{ memberLabel|e('html_attr') }}">{{ memberLabel }}</option>
                            {% endfor %}
                        </select>
                        <button type="button" class="btn btn-outline-danger remove-score" style="display: none;">Supprimer</button>
                    </div>
                </div>
                <button type="button" class="btn btn-outline-primary btn-sm" id="add-score">+ Ajouter un score</button>
            </div>

            <div class="entry-create-actions d-flex gap-2">
                <button type="submit" class="btn btn-primary">Créer l'entrée</button>
                <a href="{{ path('session_show', {'groupId': group.id, 'sessionId': session.id}) }}" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</section>

<script>
(function () {
    const container = document.getElementById('scores-container');
    const addScoreBtn = document.getElementById('add-score');
    const autoHint = document.getElementById('entry-auto-hint');
    const labelInput = document.getElementById('label');
    const labelHint = document.getElementById('entry-label-auto-hint');
    const generateLabelBtn = document.getElementById('entry-generate-label');
    const quickAddButtons = Array.from(document.querySelectorAll('.entry-member-chip'));
    const memberOptionsHtml = `
        <option value="">Membre lié (optionnel)</option>
        {% for membership in groupMembers %}
            {% set memberLabel = membership.user.displayName ?: membership.user.email %}
            <option value="{{ membership.user.id }}" data-member-label="{{ memberLabel|e('html_attr') }}">{{ memberLabel|e('html') }}</option>
        {% endfor %}
    `;

    function createScoreRow() {
        const row = document.createElement('div');
        row.className = 'score-row input-group mb-2';
        row.innerHTML = `
            <input type="text" class="form-control" name="participant_names[]" list="participant-name-suggestions" placeholder="Nom du participant" required>
            <input type="number" step="0.01" class="form-control" name="scores[]" placeholder="Score" required>
            <select class="form-control" name="participant_user_ids[]">${memberOptionsHtml}</select>
            <button type="button" class="btn btn-outline-danger remove-score">Supprimer</button>
        `;
        container.appendChild(row);
        bindRow(row);
        refreshMemberAvailability();
        updateRemoveButtons();
        return row;
    }

    function updateHint(message) {
        if (autoHint) {
            autoHint.textContent = message;
        }
    }

    function updateLabelHint(message) {
        if (labelHint) {
            labelHint.textContent = message;
        }
    }

    function updateRemoveButtons() {
        const rows = document.querySelectorAll('.score-row');
        rows.forEach((row) => {
            const btn = row.querySelector('.remove-score');
            if (rows.length > 1) {
                btn.style.display = 'block';
                btn.onclick = function () {
                    row.remove();
                    refreshMemberAvailability();
                    updateRemoveButtons();
                    applyAutoLabel();
                };
            } else {
                btn.style.display = 'none';
            }
        });
    }

    function getSelectedMemberIds(exceptSelect = null) {
        return getRows()
            .map((row) => row.querySelector('select[name="participant_user_ids[]"]'))
            .filter((select) => select && select !== exceptSelect && select.value !== '')
            .map((select) => String(select.value));
    }

    function refreshQuickAddButtons() {
        const selectedMemberIds = getSelectedMemberIds();
        quickAddButtons.forEach((button) => {
            button.disabled = selectedMemberIds.includes(String(button.dataset.memberId));
        });
    }

    function refreshSelectOptions() {
        getRows().forEach((row) => {
            const select = row.querySelector('select[name="participant_user_ids[]"]');
            if (!select) {
                return;
            }

            const blockedIds = getSelectedMemberIds(select);
            Array.from(select.options).forEach((option) => {
                option.disabled = option.value !== '' && blockedIds.includes(String(option.value));
            });
        });
    }

    function refreshMemberAvailability() {
        refreshSelectOptions();
        refreshQuickAddButtons();
    }

    function clearSyncedNameIfNeeded(input, memberLabel) {
        if (input && input.value === input.dataset.lastSyncedName && input.dataset.lastSyncedName === memberLabel) {
            input.value = '';
            input.dataset.lastSyncedName = '';
        }
    }

    function preventDuplicateSelection(row, select, memberLabel) {
        const duplicateRow = getRows().find((candidateRow) => {
            if (candidateRow === row) {
                return false;
            }

            const candidateSelect = candidateRow.querySelector('select[name="participant_user_ids[]"]');
            return candidateSelect && candidateSelect.value !== '' && candidateSelect.value === select.value;
        });

        if (!duplicateRow) {
            return false;
        }

        const nameInput = row.querySelector('input[name="participant_names[]"]');
        select.value = '';
        clearSyncedNameIfNeeded(nameInput, memberLabel);
        updateHint(memberLabel + ' est déjà sélectionné dans une autre ligne.');
        refreshMemberAvailability();
        applyAutoLabel();
        return true;
    }

    function bindRow(row) {
        const nameInput = row.querySelector('input[name="participant_names[]"]');
        const scoreInput = row.querySelector('input[name="scores[]"]');
        const select = row.querySelector('select[name="participant_user_ids[]"]');
        if (!nameInput || !scoreInput || !select) {
            return;
        }

        select.addEventListener('change', function () {
            const option = this.options[this.selectedIndex];
            if (!option || !option.value) {
                refreshMemberAvailability();
                applyAutoLabel();
                return;
            }

            const memberLabel = option.dataset.memberLabel || option.textContent || '';
            if (preventDuplicateSelection(row, this, memberLabel)) {
                return;
            }

            if (nameInput.value.trim() === '' || nameInput.value === nameInput.dataset.lastSyncedName) {
                nameInput.value = memberLabel;
                nameInput.dataset.lastSyncedName = memberLabel;
                updateHint(memberLabel + ' ajouté automatiquement dans la ligne en cours.');
            }
            refreshMemberAvailability();
            applyAutoLabel();
        });

        nameInput.addEventListener('input', function () {
            if (this.value !== this.dataset.lastSyncedName) {
                this.dataset.lastSyncedName = '';
            }
            applyAutoLabel();
        });

        scoreInput.addEventListener('input', function () {
            applyAutoLabel();
        });
    }

    function getRows() {
        return Array.from(document.querySelectorAll('.score-row'));
    }

    function findRowForMember(memberId) {
        return getRows().find((row) => {
            const select = row.querySelector('select[name="participant_user_ids[]"]');
            return select && select.value === String(memberId);
        });
    }

    function getNextAvailableRow() {
        const rows = getRows();
        return rows.find((row) => {
            const nameInput = row.querySelector('input[name="participant_names[]"]');
            const scoreInput = row.querySelector('input[name="scores[]"]');
            const select = row.querySelector('select[name="participant_user_ids[]"]');
            return nameInput && scoreInput && select && nameInput.value.trim() === '' && scoreInput.value.trim() === '' && select.value === '';
        }) || createScoreRow();
    }

    function applyMemberToRow(row, memberId, memberLabel) {
        const nameInput = row.querySelector('input[name="participant_names[]"]');
        const scoreInput = row.querySelector('input[name="scores[]"]');
        const select = row.querySelector('select[name="participant_user_ids[]"]');
        if (!nameInput || !scoreInput || !select) {
            return;
        }

        select.value = String(memberId);
        nameInput.value = memberLabel;
        nameInput.dataset.lastSyncedName = memberLabel;
        scoreInput.focus();
        updateHint(memberLabel + ' ajouté. Tu peux saisir son score.');
        applyAutoLabel();
    }

    function buildAutoLabel() {
        const filledNames = getRows()
            .map((row) => row.querySelector('input[name="participant_names[]"]'))
            .filter(Boolean)
            .map((input) => input.value.trim())
            .filter((value, index, values) => value !== '' && values.indexOf(value) === index);

        if (filledNames.length === 0) {
            return '';
        }

        const previewNames = filledNames.slice(0, 3);
        const suffix = filledNames.length > 3 ? ' +' + (filledNames.length - 3) : '';
        return 'Classement ' + previewNames.join(', ') + suffix;
    }

    function applyAutoLabel(force = false) {
        if (!labelInput) {
            return;
        }

        const autoLabel = buildAutoLabel();
        if (labelInput.dataset.userEdited === 'true' && !force) {
            updateLabelHint('Titre personnalisé conservé.');
            return;
        }

        labelInput.value = autoLabel;
        updateLabelHint(autoLabel ? 'Titre proposé à partir des participants.' : 'Le titre se complètera dès que tu ajoutes des participants.');
    }

    addScoreBtn.addEventListener('click', function () {
        const row = createScoreRow();
        const firstInput = row.querySelector('input[name="participant_names[]"]');
        if (firstInput) {
            firstInput.focus();
        }
        applyAutoLabel();
    });

    if (labelInput) {
        labelInput.addEventListener('input', function () {
            this.dataset.userEdited = this.value.trim() !== '' ? 'true' : 'false';
            if (this.dataset.userEdited === 'false') {
                applyAutoLabel(true);
            } else {
                updateLabelHint('Titre personnalisé conservé.');
            }
        });
    }

    if (generateLabelBtn) {
        generateLabelBtn.addEventListener('click', function () {
            if (labelInput) {
                labelInput.dataset.userEdited = 'false';
            }
            applyAutoLabel(true);
        });
    }

    quickAddButtons.forEach((button) => {
        button.addEventListener('click', function () {
            const memberId = this.dataset.memberId;
            const memberLabel = this.dataset.memberLabel || '';
            const existingRow = findRowForMember(memberId);
            if (existingRow) {
                const scoreInput = existingRow.querySelector('input[name="scores[]"]');
                if (scoreInput) {
                    scoreInput.focus();
                }
                updateHint(memberLabel + ' est déjà présent.');
                return;
            }

            applyMemberToRow(getNextAvailableRow(), memberId, memberLabel);
        });
    });

    getRows().forEach(bindRow);
    refreshMemberAvailability();
    applyAutoLabel();
    updateHint('Ajoute vite des membres avec les badges ci-dessus.');
    updateRemoveButtons();
})();
</script>
{% endblock %}
