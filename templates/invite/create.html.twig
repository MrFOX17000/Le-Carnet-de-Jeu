{% extends 'base.html.twig' %}

{% block title %}Inviter un membre - {{ group.name }}{% endblock %}

{% block body %}
  <h1>Inviter un membre au groupe "{{ group.name }}"</h1>

  {% for message in app.flashes('success') %}
    <div class="alert alert-success">
      {{ message }}
    </div>
  {% endfor %}

  {% for message in app.flashes('error') %}
    <div class="alert alert-danger">
      {{ message }}
    </div>
  {% endfor %}

  <form method="post">
    <div>
      <label for="email">Email du membre à inviter</label>
      <input type="email" id="email" name="email" required>
    </div>

    <button type="submit">Créer l’invitation</button>
  </form>

  <p>
    <a href="{{ path('group_show', { id: group.id }) }}">Retour au groupe</a>
  </p>
{% endblock %}
