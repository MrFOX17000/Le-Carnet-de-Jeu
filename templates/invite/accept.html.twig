{% extends 'base.html.twig' %}

{% block title %}Accepter une invitation{% endblock %}

{% block body %}
  <section class="invite-page">
    <div class="invite-card invite-card-accept">
      <p class="invite-kicker">Invitation reçue</p>
      <h1>Accepter une invitation</h1>

      {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
      {% endfor %}

      <div class="invitation-details">
        <p>Vous avez été invité à rejoindre le groupe :</p>
        <h2>{{ invite.group.name }}</h2>

        <dl class="invite-details-grid">
          <dt>Rôle</dt>
          <dd>{{ invite.role.value }}</dd>

          <dt>Invitation créée par</dt>
          <dd>{{ invite.createdBy.email }}</dd>

          <dt>Expire le</dt>
          <dd>{{ invite.expiresAt|date('d/m/Y H:i') }}</dd>
        </dl>
      </div>

      <form method="post" class="invite-actions">
        <button class="btn btn-primary" type="submit" name="accept" value="yes">Accepter l'invitation</button>
        <a class="btn btn-secondary" href="{{ path('group_index') }}">Annuler</a>
      </form>
    </div>
  </section>
{% endblock %}
