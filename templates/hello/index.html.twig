{% extends 'base.html.twig' %}

{% block title %}Carnet de Jeu - Tracker de sessions gaming{% endblock %}

{% block body %}
<div class="home-variant{% if is_corporate %} home-corporate{% endif %}">
<div class="variant-switch" data-reveal>
    <a class="variant-link{% if not is_corporate %} active{% endif %}" href="{{ path('app_home') }}">Style gaming</a>
    <a class="variant-link{% if is_corporate %} active{% endif %}" href="{{ path('app_home', {variant: 'corporate'}) }}">Style corporate</a>
</div>

<section class="hero-premium" data-reveal>
    <div class="hero-content">
        <p class="eyebrow">{% if is_corporate %}Pilotage clair. Equipes alignees.{% else %}Organize. Track. Dominate.{% endif %}</p>
        <h1 class="hero-title">Votre carnet de jeu <span class="gradient-text">dans le cloud</span></h1>
        <p class="hero-subtitle">
            Suivez vos sessions de jeu en groupe, enregistrez vos scores, et consultez des statistiques fiables.
            Pour tous les jeux et pour tous les groupes.
        </p>

        <div class="hero-actions">
            {% if app.user %}
                <a class="btn btn-primary btn-large" href="{{ path('dashboard') }}">Acceder au dashboard</a>
                <a class="btn btn-secondary btn-large" href="{{ path('group_index') }}">Voir mes groupes</a>
            {% else %}
                <a class="btn btn-primary btn-large" href="{{ path('app_register') }}">Creer un compte</a>
                <a class="btn btn-secondary btn-large" href="{{ path('app_login') }}">Se connecter</a>
            {% endif %}
        </div>

        <div class="hero-metrics" aria-label="Indicateurs de qualite">
            <span class="hero-chip">112 tests automatises</span>
            <span class="hero-chip">355 assertions</span>
            <span class="hero-chip">Isolation multi-groupes</span>
        </div>
    </div>

    <div class="hero-visual">
        <picture>
            <source srcset="{{ asset('images/brand/logo-carnet-de-jeu.webp') }}" type="image/webp">
            <source srcset="{{ asset('images/brand/logo-carnet-de-jeu.png') }}" type="image/png">
            <img class="hero-logo" src="{{ asset('images/brand/logo-carnet-de-jeu.png') }}" alt="Carnet de Jeu">
        </picture>
    </div>
</section>

<section class="use-cases" data-reveal>
    <h2 class="section-title">Pour tous vos jeux</h2>
    <p class="section-subtitle">Vos visuels sont en fond, avec un texte lisible et impactant.</p>

    <div class="use-case-grid" data-reveal>
        <article class="use-case-card" data-reveal style="background-image: url('{{ asset('images/use-cases/chess.webp') }}'), url('{{ asset('images/use-cases/chess.jpg') }}'), url('{{ asset('images/use-cases/chess.svg') }}')">
            <div class="use-case-overlay">
                <h3>Jeux de plateau</h3>
                <p>Echecs, Catan, Carcassonne: suivez les scores et les performances.</p>
            </div>
        </article>

        <article class="use-case-card" data-reveal style="background-image: url('{{ asset('images/use-cases/cards.webp') }}'), url('{{ asset('images/use-cases/cards.jpg') }}'), url('{{ asset('images/use-cases/cards.svg') }}')">
            <div class="use-case-overlay">
                <h3>Jeux de cartes</h3>
                <p>Magic, Poker, Tarot: enregistrez les parties et les resultats.</p>
            </div>
        </article>

        <article class="use-case-card" data-reveal style="background-image: url('{{ asset('images/use-cases/esports.webp') }}'), url('{{ asset('images/use-cases/esports.jpg') }}'), url('{{ asset('images/use-cases/esports.svg') }}')">
            <div class="use-case-overlay">
                <h3>Esport et gaming</h3>
                <p>Rocket League, CS2, Valorant: centralisez vos stats d'equipe.</p>
            </div>
        </article>

        <article class="use-case-card" data-reveal style="background-image: url('{{ asset('images/use-cases/sports.webp') }}'), url('{{ asset('images/use-cases/sports.jpg') }}'), url('{{ asset('images/use-cases/sports.svg') }}')">
            <div class="use-case-overlay">
                <h3>Sports competitifs</h3>
                <p>Foot, tennis, basket: journalisez matchs, equipes et statistiques.</p>
            </div>
        </article>

        <article class="use-case-card" data-reveal style="background-image: url('{{ asset('images/use-cases/rpg.webp') }}'), url('{{ asset('images/use-cases/rpg.jpg') }}'), url('{{ asset('images/use-cases/rpg.svg') }}')">
            <div class="use-case-overlay">
                <h3>Jeux de role</h3>
                <p>D&D, Pathfinder et autres: gardez l'historique de vos campagnes.</p>
            </div>
        </article>

        <article class="use-case-card" data-reveal style="background-image: url('{{ asset('images/use-cases/escape.webp') }}'), url('{{ asset('images/use-cases/escape.jpg') }}'), url('{{ asset('images/use-cases/escape.svg') }}')">
            <div class="use-case-overlay">
                <h3>Escape games</h3>
                <p>Temps, enigmes resolues, progression: tout est centralise au meme endroit.</p>
            </div>
        </article>
    </div>
</section>

<section class="why-section" data-reveal>
    <h2 class="section-title">Pourquoi Carnet de Jeu</h2>
    <div class="why-grid">
        <article class="why-card">
            <h3>Isolation stricte</h3>
            <p>Un groupe ne voit jamais les donnees d'un autre groupe.</p>
        </article>
        <article class="why-card">
            <h3>Statistiques fiables</h3>
            <p>Chaque resultat peut etre rattache a un membre precis.</p>
        </article>
        <article class="why-card">
            <h3>Gestion simple</h3>
            <p>Invitez vos amis, attribuez les roles, suivez l'historique.</p>
        </article>
        <article class="why-card">
            <h3>Rapide et solide</h3>
            <p>Backend Symfony, architecture claire et tests automatises.</p>
        </article>
    </div>
</section>

<section class="how-it-works" data-reveal>
    <h2 class="section-title">Comment ca marche</h2>
    <div class="steps">
        <div class="step">
            <div class="step-number">1</div>
            <h3>Creez un groupe</h3>
            <p>Donnez un nom et invitez les joueurs.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
            <div class="step-number">2</div>
            <h3>Ajoutez les sessions</h3>
            <p>Scores simples ou details complets, selon vos besoins.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
            <div class="step-number">3</div>
            <h3>Suivez vos stats</h3>
            <p>Visualisez les performances de votre groupe dans le temps.</p>
        </div>
    </div>
</section>

<section class="cta-section" data-reveal>
    <div class="cta-content">
        <h2>Pret a commencer?</h2>
        <p>Creez votre premier groupe en moins d'une minute.</p>
        {% if not app.user %}
            <a class="btn btn-primary btn-xl" href="{{ path('app_register') }}">Creer mon compte</a>
        {% else %}
            <a class="btn btn-primary btn-xl" href="{{ path('group_create_form') }}">Creer un groupe</a>
        {% endif %}
    </div>
</section>

<section class="faq-section" data-reveal>
    <h2 class="section-title">Questions frequentes</h2>
    <div class="faq-container">
        <details class="faq-item">
            <summary class="faq-question"><span>C'est gratuit?</span><span class="faq-toggle">+</span></summary>
            <div class="faq-answer"><p>Oui. Toutes les fonctions principales sont disponibles sans paiement.</p></div>
        </details>
        <details class="faq-item">
            <summary class="faq-question"><span>Mes donnees sont securisees?</span><span class="faq-toggle">+</span></summary>
            <div class="faq-answer"><p>Oui. Chaque groupe est isole et accessible seulement a ses membres.</p></div>
        </details>
        <details class="faq-item">
            <summary class="faq-question"><span>Je peux partager sans compte?</span><span class="faq-toggle">+</span></summary>
            <div class="faq-answer"><p>Oui, via des liens publics en lecture seule.</p></div>
        </details>
    </div>
</section>

<section class="social-proof" data-reveal>
    <h2 class="section-title">C'est du serieux</h2>
    <div class="proof-grid">
        <div class="proof-item">
            <div class="proof-number">112</div>
            <div class="proof-label">Tests automatises</div>
        </div>
        <div class="proof-item">
            <div class="proof-number">355</div>
            <div class="proof-label">Assertions verifiees</div>
        </div>
        <div class="proof-item">
            <div class="proof-number">7</div>
            <div class="proof-label">Couches d'architecture</div>
        </div>
        <div class="proof-item">
            <div class="proof-number">100%</div>
            <div class="proof-label">Orientation jeu en groupe</div>
        </div>
    </div>
</section>

</div>

{% endblock %}
